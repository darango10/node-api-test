# =============================================================================
# Docker Ignore File
# =============================================================================
# Excludes files from Docker build context for security, performance, and
# smaller image size. This follows Node.js best practices from
# goldbergyoni/nodebestpractices.
# =============================================================================

# -----------------------------------------------------------------------------
# Security: Secrets and Credentials
# -----------------------------------------------------------------------------
# CRITICAL: Never include secrets in Docker images
.env
.env.*
*.env
.env.local
.env.development
.env.production
.env.test
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/
credentials/
config/secrets.json

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
# Exclude pre-built files (will be generated during Docker build)
node_modules/
dist/
build/
coverage/
.cache/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.github/
.gitlab-ci.yml

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test/
*.test.ts
*.spec.ts
vitest.config.ts
coverage/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
README.md
LICENSE
CHANGELOG.md
*.md

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab/
.circleci/
.travis.yml
Jenkinsfile
azure-pipelines.yml

# -----------------------------------------------------------------------------
# Docker Files (not needed inside container)
# -----------------------------------------------------------------------------
Dockerfile
Dockerfile.*
docker-compose.yml
docker-compose.*.yml
.dockerignore

# -----------------------------------------------------------------------------
# Logs and Temp Files
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Specifications and Planning
# -----------------------------------------------------------------------------
specs/
.specify/
.cursor/

# -----------------------------------------------------------------------------
# Linting and Formatting
# -----------------------------------------------------------------------------
.eslintrc*
.prettierrc*
.prettierignore
.editorconfig

# -----------------------------------------------------------------------------
# Package Manager Files (keep only essential ones)
# -----------------------------------------------------------------------------
# NOTE: package.json and package-lock.json are explicitly included
# Exclude other package manager files
yarn.lock
pnpm-lock.yaml
.npmrc
.yarnrc

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.husky/
*.bak
*.tmp
*.temp
